generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
}

model InventoryItems {
  item_id    Int      @id @default(autoincrement())
  product    Products @relation(fields: [product_id], references: [product_id])
  product_id Int
  user       Users    @relation(fields: [user_id], references: [user_id])
  user_id    Int
  date_added DateTime @default(now())
  price      Float
}

model Products {
  product_id   Int     @id @default(autoincrement())
  upc          String
  product_name String
  brand        String
  image_link   String?
  items        InventoryItems[]
  recalls      Recalls[]
}

model Recalls {
  recall_id        Int      @id @default(autoincrement())
  product          Products @relation(fields: [product_id], references: [product_id])
  product_id       Int
  is_active        Boolean
  description      String
  recall_date      DateTime
  company          String
  regions          String  @default("")
  amount_sick      Int     @default(0)
  amount_dead      Int     @default(0)
  product_keywords String  @default("")
  classification   String  @default("")
}

model Users { 
  user_id         Int    @id @default(autoincrement())
  first_name      String
  last_name       String
  email           String
  password        String
  has_premium     Boolean
  free_scans_left Int?
  verification_token String? 
  is_verified       Boolean  @default(false)
  items           InventoryItems[]
}

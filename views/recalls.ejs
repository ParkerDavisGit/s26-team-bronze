<!doctype html>
<html lang="en">
  <head>

    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <!-- <title>Spoiler Alert Homepage</title> -->
     <title><%= title %></title>
    <link href="css/bootstrap.css" rel="stylesheet">
  
    <style>
      html, body {
        min-height: 100%;
      }

      body {
        background:
          linear-gradient(#00000080, #000000BF),
          url(/assets/img/bg-img-1.jpg) center/cover no-repeat fixed;
      }
    </style>

  </head>
  
  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-black">
      <div class="container-fluid">
        <a class="navbar-brand" style="color: #EAA221" href="#"><%= title %></a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarSupportedContent">
          <ul class="navbar-nav me-auto mb-2 mb-lg-0">
            <li class="nav-item">
              <a class="nav-link" style="color: #EAA221" href="/">Home</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" style="color: #EAA221" href="/pantry">Pantry</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" style="color: #EAA221" href="/settings">Settings</a>
            </li>
            <% if (!isLoggedIn) { %>
              <li class="nav-item">
                <a class="nav-link" style="color: #EAA221" href="/login">Log In</a>
              </li>
            <% } else { %>
              <li class="nav-item">
                <a class="nav-link" style="color: #EAA221" href="/logout">Log Out</a>
              </li>
            <% } %>
          </ul>
          <form class="d-flex" role="search">
            <input class="form-control me-2" style="border-color: #EAA221;" type="search" placeholder="Search" aria-label="Search"/>
            <button class="btn" style="border-color: #EAA221; color: #EAA221" type="submit">Search</button>
          </form>
        </div>
      </div>
    </nav>

<!-- Title -->
  <div class = "container" style="margin-top: 50px; margin-bottom: 50px; padding-bottom: 25px; border-bottom: solid 2px;">
    <h1 style="color: #EAA221; text-align: center; text-shadow: 2px 2px 3px black;"><%= title %></h1>
  </div>

    <!-- Banner -->
  <div class = "container">
    
  </div>

  <!-- All Recalls -->
  <div class="container">
    <% if (!recall_data || recall_data.length === 0) { %>
      <p>No recalls found.</p>
    <% } else { %>
      <% recall_data.forEach(recall => { %>
        <div class="container" style="display: flex; justify-content: center;">
          <div class="card mb-3" style="width: 100vh;">
            <h3 class="card-header"><%=recall.recall_date %></h3>
            <div class="card-body">
              <h5 class="card-title"><%= recall.company %></h5>
              <h5 class="card-title"><%= recall.product_name %></h5>
              <h6 class="card-subtitle text-muted"><%= recall.classification %></h6>
              <button class = "btn btn-outline-secondary mt-3 mb-3" 
                      type = "button" 
                      data-bs-toggle="collapse" 
                      data-bs-target="#recallDetails<%= recall.recall_id %>">
                View Details
              </button>
              <div class="collapse" id = "recallDetails<%= recall.recall_id %>">
                <div class="card-body border-top">
                  <p class="card-text">Description: <%= recall.description %></p>
                  <p class="card-text">Regions: <%= recall.regions %></p>
                  <p class="card-text">People Affected: <%= recall.amount_sick %></p>
                  <p class="card-text">Deaths: <%= recall.amount_dead %></p>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
  
  </body>
</html>
<!doctype html>
<html lang="en">

<head>

  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <!-- <title>Spoiler Alert Homepage</title> -->
  <title>
    <%= title %>
  </title>
  <link href="css/bootstrap.css" rel="stylesheet">

</head>

<body
  style="background: linear-gradient(#00000080, #00000080), url(/assets/img/bg-img-3.jpg) center/cover no-repeat fixed;">

  <nav class="navbar navbar-expand-lg navbar-dark bg-black">
    <div class="container-fluid">
      <a class="navbar-brand" style="color: #EAA221" href="#">
        <%= title %>
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent"
        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarSupportedContent">
        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
          <li class="nav-item">
            <a class="nav-link" style="color: #EAA221" href="/">Home</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" style="color: #EAA221" href="/recalls">Recalls</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" style="color: #EAA221" href="/settings">Settings</a>
          </li>
          <% if (!isLoggedIn) { %>
            <li class="nav-item">
              <a class="nav-link" style="color: #EAA221" href="/login">Log In</a>
            </li>
            <% } else { %>
              <li class="nav-item">
                <a class="nav-link" style="color: #EAA221" href="/logout">Log Out</a>
              </li>
              <% } %>
        </ul>
        <form class="d-flex" role="search" action="/pantry" method="GET">
          <input class="form-control me-2" style="border-color: #EAA221;" type="search" name="search" placeholder="Search inventory..."
            aria-label="Search" value="<%= searchQuery %>" />
          <button class="btn" style="border-color: #EAA221; color: #EAA221" type="submit">Search</button>
        </form>
      </div>
  </nav>

  <!-- Title -->
  <div class="container" style="margin-top: 50px; margin-bottom: 50px; padding-bottom: 25px; border-bottom: solid 2px;">
    <h1 style="color: #EAA221; text-align: center; text-shadow: 2px 2px 3px black;">
      <%= title %>
    </h1>
  </div>

  <!-- Banner -->
  <div class="container">

  </div>

  <!-- Search Bar with Button -->
  <div class="container" style="margin-top: 50px; margin-bottom: 50px; padding-bottom: 25px; border-bottom: solid 2px;">
    <% if (error) { %>
      <div class="alert alert-danger text-center" role="alert" style="max-width: 400px; margin: 0 auto 20px auto;">
        <%= error %>
      </div>
    <% } %>
    <form action="/pantry/add" method="POST">
      <div class="input-group mb-3" style="max-width: 400px; margin: 0 auto;">
        <input type="text" inputmode="numeric" oninput="this.value = this.value.replace(/[^0-9]/g, '')" pattern="[0-9]*"
          name="upc" class="form-control" placeholder="Enter UPC to Add to Pantry" aria-label="UPC Lookup" required>
        <button class="btn btn-primary" type="submit"
          style="color: #EAA221; border-color: #EAA221; background-color: black;" id="button-addon2">Add</button>
      </div>
    </form>
  </div>

  <!-- Banner -->
  <div class="container">

  </div>

  <!-- Pantry Item List -->
  <div class="container">
    <% if (isLoggedIn) { %>
      <% if (!food_data || food_data.length===0) { %>
        <p>No pantry items.</p>
        <% } else { %>
          <% food_data.forEach(item=> { %>
            <div class="container" style="display: flex; justify-content: center;">
              <div class="card mb-3" style="width: 100vh; background-color: black; --bs-card-border-color: #EAA221">
                <div class="card-header d-flex justify-content-between align-items-center">
                  <h3 style="color: #EAA221">
                    <%= item.product.product_name %>
                  </h3>
                  <form action="/pantry/remove" method="POST" style="margin: 0;">
                    <input type="hidden" name="item_id" value="<%= item.item_id %>">
                    <button class="btn btn-outline-danger" type="submit" onclick="return confirm('Remove this item?')">
                      ✕
                    </button>
                  </form>
                </div>
                <div class="card-body">
                  <h5 class="card-title" style="color: #EAA221">Brand: <%= item.product.brand %>
                  </h5>
                  <h6 class="card-subtitle" style="color: #EAA221">UPC: <%= item.product.upc %>
                  </h6>

                  <!-- Display Recall Information -->
                  <% if (item.product.recalls.length !=0) { %>
                    <button class="btn btn-danger mt-3 mb-2" type="button" data-bs-toggle="collapse"
                      data-bs-target="#recallDetails<%= item.product.product_id %>" aria-expanded="false"
                      aria-controls="recallDetails<%= item.product.product_id %>">
                      Recall Alert
                    </button>

                    <div class="collapse" id="recallDetails<%= item.product.product_id %>">
                      <div class="card-body border-top" style="--bs-border-color: #EAA221;">
                        <p class="card-text" style="color: #EAA221">Recall Date: <%= item.product.recalls[0].recall_date
                            %>
                        </p>
                        <p class="card-text" style="color: #EAA221">Company: <%= item.product.recalls[0].company %>
                        </p>
                        <p class="card-text" style="color: #EAA221">Classification: <%=
                            item.product.recalls[0].classification %>
                        </p>
                        <p class="card-text" style="color: #EAA221">Description: <%= item.product.recalls[0].description
                            %>
                        </p>
                        <p class="card-text" style="color: #EAA221">Regions: <%= item.product.recalls[0].regions %>
                        </p>
                        <p class="card-text" style="color: #EAA221">People Affected: <%=
                            item.product.recalls[0].amount_sick %>
                        </p>
                        <p class="card-text" style="color: #EAA221">Deaths: <%= item.product.recalls[0].amount_dead %>
                        </p>
                      </div>
                    </div>
                    <% } %>
                </div>
              </div>
            </div>
            <% }) %>
              <% } %>
                <% } %>
  </div>

  <!-- Pages Buttons -->
  <div class="container d-flex justify-content-center mt-4 mb-4">
    <div>
      <% if (currentPage> 1) { %>
        <a class="btn btn-primary me-2" style="color: black; background-color: #EAA221; --bs-btn-border-color: black;"
          href="/pantry?page=<%= currentPage - 1 %><%= searchQuery ? '&search=' + encodeURIComponent(searchQuery) : '' %>">Previous
        </a>
        <% } %>

          <% if (currentPage < totalPages) { %>
            <a class="btn btn-primary" style="color: black; background-color: #EAA221; --bs-btn-border-color: black;"
              href="/pantry?page=<%= currentPage + 1 %><%= searchQuery ? '&search=' + encodeURIComponent(searchQuery) : '' %>">Next
            </a>
            <% } %>
    </div>
  </div>

  <!-- Login Modal -->
  <div class="modal fade" id="loginRequiredModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content" style="background-color:black; --bs-modal-border-color:#EAA221;">

        <div class="modal-header">
          <h3 class="modal-title" style="color:#EAA221;">Login Required</h3>
        </div>

        <div class="modal-body">
          <p style="color:#EAA221;">You must be logged in to view this page.</p>
        </div>

        <div class="modal-footer">
          <a href="/" class="btn btn-outline-light" style="color:#EAA221; --bs-btn-border-color: #EAA221;">Return
            Home</a>
          <a href="/login" class="btn btn-warning" style="color: black;">Log In</a>
        </div>

      </div>
    </div>
  </div>

  <% if (!isLoggedIn) { %>
    <script>
      window.onload = function () {
        const modal = new bootstrap.Modal(document.getElementById('loginRequiredModal'));
        modal.show();
      };
    </script>
    <% } %>


      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>

</body>

</html>
<!doctype html>
<html lang="en">
  <head>

    <%- include('partials/head') %>

    <style>
      html, body {
        min-height: 100%;
      }

      body {
        background:
          linear-gradient(#00000080, #000000BF),
          url(/assets/img/bg-img-1.jpg) center/cover no-repeat fixed;
      }
    </style>


  </head>
  
  <body>
    <div style="display: flex;">


<!-- Collapsible Sidebar -->
<div class="offcanvas offcanvas-start bg-black"
     tabindex="-1"
     id="sidebarMenu"
     aria-labelledby="sidebarMenuLabel">

  <div class="offcanvas-header">
    <h5 class="offcanvas-title" id="sidebarMenuLabel" style="color: #EAA221;">Menu</h5>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
  </div>

  <div class="offcanvas-body">
    <a href="/recalls" style="display: block; color: #EAA221; padding: 15px; text-decoration: none;">Recalls</a>
    <a href="/pantry" style="display: block; color: #EAA221; padding: 15px; text-decoration: none;">Pantry</a>
    <a href="/settings" style="display: block; color: #EAA221; padding: 15px; text-decoration: none;">Settings</a>
  </div>
</div>

  <!-- Main Content -->
  <div style="flex-grow: 1;">
    <!-- Hamburger Button -->
<button class="btn m-3"
        style="background-color: black; color: #EAA221; border-color: #EAA221; height: 45px;"
        type="button"
        data-bs-toggle="offcanvas"
        data-bs-target="#sidebarMenu"
        aria-controls="sidebarMenu">
  ☰
</button>

        <!-- Navbar -->
    <%- include('partials/navbar') %>

      <!-- Title -->
  <div class = "container" style="margin-top: 50px; margin-bottom: 50px; padding-bottom: 25px; border-bottom: solid 2px;">
<h1 style="color: #EAA221; font-size: 64px; text-align: center; text-shadow: 2px 2px 3px black;">
  Welcome<% if (firstName) { %>, <%= firstName %><% } %>
</h1>
</div>

    <!-- Banner -->
  <div class = "container">
    <!-- Recall Stats -->
    <div class="row mb-4">
      <div class="col-md-6 mb-3">
        <div class="card text-white bg-info h-100">
          <div class="card-header d-flex justify-content-between align-items-center">
            <h6 class="mb-0">🛡️ FDA Food Safety Status</h6>
            <select id="recallPeriod" class="form-select form-select-sm w-auto text-dark">
              <option value="<%= recallsPastMonth %>">Past Month</option>
              <option value="<%= recallsPast3Months %>">Past 3 Months</option>
              <option value="<%= recallsPastYear %>">Past Year</option>
              <option value="<%= recallsAllTime %>">All Time</option>
            </select>
          </div>
          <div class="card-body">
            <h3 class="card-title mb-0" id="recallCount"><%= recallsPastMonth.toLocaleString() %></h3>
            <p class="card-text">FDA recalls in selected period</p>
          </div>
        </div>
      </div>
      <% if (isLoggedIn) { %>
        <div class="col-md-6 mb-3">
          <div class="card text-white h-100 <%= userPantryRecalls > 0 ? 'bg-danger' : 'bg-success' %>">
            <div class="card-header"><h6 class="mb-0"><%= userPantryRecalls > 0 ? '⚠️ Pantry Alert' : '✅ Pantry Status' %></h6></div>
            <div class="card-body">
              <h3 class="card-title mb-0"><%= userPantryRecalls %></h3>
              <p class="card-text"><%= userPantryRecalls > 0 ? 'Recalled items in your pantry' : 'No recalled items in your pantry' %></p>
              <% if (userPantryRecalls > 0) { %>
                <a href="/pantry" class="btn btn-light btn-sm">Check Pantry →</a>
              <% } %>
            </div>
          </div>
        </div>
      <% } %>
    </div>
    <script>
      document.getElementById('recallPeriod').addEventListener('change', function () {
        document.getElementById('recallCount').textContent = Number(this.value).toLocaleString();
      });
    </script>
  </div>

  <!-- All Recalls -->
  <div class="container">
    <% if (!recall_data || recall_data.length === 0) { %>
      <p>No recalls found.</p>
    <% } else { %>
      <% recall_data.forEach(recall => { %>
        <div class="container" style="display: flex; justify-content: center;">
          <div class="card mb-3" style="width: 100vh;">
            <h3 class="card-header"><%=recall.recall_date %></h3>
            <div class="card-body">
              <h5 class="card-title"><%= recall.company %></h5>
              <h5 class="card-title"><%= recall.product_name %></h5>
              <h6 class="card-subtitle text-muted"><%= recall.classification %></h6>
              <button class = "btn btn-outline-secondary mt-3 mb-3" 
                      type = "button" 
                      data-bs-toggle="collapse" 
                      data-bs-target="#recallDetails<%= recall.recall_id %>">
                View Details
              </button>
              <div class="collapse" id = "recallDetails<%= recall.recall_id %>">
                <div class="card-body border-top">
                  <p class="card-text">Description: <%= recall.description %></p>
                  <p class="card-text">Regions: <%= recall.regions %></p>
                  <p class="card-text">People Affected: <%= recall.amount_sick %></p>
                  <p class="card-text">Deaths: <%= recall.amount_dead %></p>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    </div>
</div>
  </body>
</html>